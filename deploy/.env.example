# ==========================================
# CẤU HÌNH PRODUCTION ENVIRONMENT SOLAR O&M
# Copy file này thành .env và điền các giá trị thực tế
# ==========================================

# 1. Database (PostgreSQL) - Chạy độc lập trong Docker tại port 2602
DB_DRIVER=postgres
DB_HOST=db
DB_PORT=2602
DB_USER=phucraitek0539
DB_PASSWORD=090103Phuc
DB_NAME=solar_om
DATABASE_URL=postgres://phucraitek0539:090103Phuc@db:2602/solar_om?sslmode=disable

# 2. MinIO - Chạy độc lập trong Docker tại port 2603 (API) và 2604 (Console)
MINIO_ENDPOINT=minio:2603
MINIO_ACCESS_KEY=phucraitek0539
MINIO_SECRET_KEY=090103Phuc
MINIO_BUCKET=dev
MINIO_USE_SSL=false

# 3. Security
# Chuỗi JWT bí mật để ký token đăng nhập (Đổi thành chuỗi ngẫu nhiên dài)
JWT_SECRET=YOUR_SUPER_SECRET_STRING_JWT
# Cho phép tất cả các Origin gọi API
ALLOWED_ORIGINS=*

# 4. Web Push Notifications
# Lấy cặp khóa tại https://www.vapidkeys.com/
VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=YOUR_VAPID_PRIVATE_KEY

